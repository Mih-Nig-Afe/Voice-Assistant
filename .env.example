# Voice Assistant Environment Configuration
# Copy this file to .env and fill in your values

# ── API Keys ────────────────────────────────────────────────────────

# Groq API Key (FREE — primary AI backend, llama-3.3-70b-versatile)
# Sign up at: https://console.groq.com (free, no credit card)
GROQ_API_KEY=your_groq_api_key_here

# OpenWeather API Key (FREE — for weather feature)
# Sign up at: https://openweathermap.org/api (free tier: 1000 calls/day)
OPENWEATHER_API_KEY=your_api_key_here

# GNews API Key (FREE — for news headlines, optional)
# Sign up at: https://gnews.io (free tier: 100 requests/day)
# If not set, falls back to Google News RSS (no key needed)
GNEWS_API_KEY=your_gnews_api_key_here

# ── General Settings ────────────────────────────────────────────────

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# TTS engine preference (auto, pyttsx3)
TTS_ENGINE=auto

# Interaction mode (auto, voice, text)
# auto: voice on local machines with microphone, text in Docker/headless
# Docker tip: use `docker run -it ...` or `docker compose run --rm miehab` for typing
INTERACTION_MODE=auto

# Require GROQ_API_KEY at startup when AI_BACKEND=groq
REQUIRE_GROQ_API_KEY=true

# If voice is requested but unavailable, fail fast instead of silently falling back
FAIL_IF_VOICE_UNAVAILABLE=true

# Speech recognition timeout (seconds)
LISTEN_TIMEOUT=8
PHRASE_TIME_LIMIT=12

# HTTP request timeouts (seconds)
HTTP_TIMEOUT=10
HTTP_CONNECT_TIMEOUT=5

# ── AI Settings ─────────────────────────────────────────────────────

# AI backend: groq (recommended) or huggingface (local, no API key needed)
AI_BACKEND=groq
# Primary model name (current default on this project: llama-3.3-70b-versatile)
AI_MODEL=llama-3.3-70b-versatile
# Optional fallback chain (comma-separated) used if primary fails/returns empty
AI_MODEL_FALLBACKS=openai/gpt-oss-120b,qwen/qwen3-32b
AI_MAX_LENGTH=150
AI_MAX_HISTORY=20

# Speech-to-text model for web microphone fallback (Groq Whisper)
# Options: whisper-large-v3 (better accuracy) | whisper-large-v3-turbo (faster)
STT_MODEL=whisper-large-v3
STT_LANGUAGE=en
# Optional phrase biasing for names/locations common in your usage.
STT_PROMPT=Transcribe spoken assistant requests clearly. Common city names include Addis Ababa, Hawassa, Shashamane, Adama, Dire Dawa, Bahir Dar, Gode, and Jijiga. Common world-news terms include Iran, Israel, US, and USA.

# Web speech output backend:
# edge (server neural voice), browser (local browser voice), auto (same as edge)
WEB_TTS_BACKEND=edge
WEB_TTS_VOICE=en-US-AvaMultilingualNeural
WEB_TTS_RATE=+0%
WEB_TTS_PITCH=+0Hz
WEB_TTS_MAX_CHARS=900
