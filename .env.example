# Voice Assistant Environment Configuration
# Copy this file to .env and fill in your values

# OpenWeather API Key (required for weather feature)
# Get yours at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# TTS engine preference (auto, pyttsx3)
# "auto" will try platform-native first, then fallback to pyttsx3
TTS_ENGINE=auto

# Speech recognition timeout (seconds)
LISTEN_TIMEOUT=8
PHRASE_TIME_LIMIT=12

# AI model name (HuggingFace model identifier)
AI_MODEL=EleutherAI/gpt-neo-125M
AI_MAX_LENGTH=100

